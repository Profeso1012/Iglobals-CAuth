{
  "name": "iglobals-central-auth",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "web",
    "sdk-js",
    "sdk-py"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=web",
    "build": "npm run build --workspace=web",
    "start": "npm run start --workspace=web",
    "build:sdk-js": "npm run build --workspace=sdk-js",
    "build:sdk-py": "cd sdk-py && python -m build",
    "build:sdks": "npm run build:sdk-js && npm run build:sdk-py",
    "generate-keys": "node scripts/generate-keys.js",
    "migrate": "node scripts/run-migrations.js"
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "pg": "^8.11.5"
  }
}
